# ============================================================
# CareChain — Exemplo de variáveis de ambiente
# Copie este arquivo para ".env" e preencha os valores.
# O arquivo .env NÃO deve ser versionado no git (já está no .gitignore).
# ============================================================

# --- Deploy em testnet pública (Sepolia) — OPCIONAL ---
# URL de um provedor RPC (ex.: Alchemy, Infura, ou público).
SEPOLIA_RPC_URL="https://sepolia.infura.io/v3/SEU_PROJECT_ID"

# Chave privada da carteira que fará o deploy na Sepolia.
# Use SEMPRE uma carteira de teste, nunca uma com fundos reais.
PRIVATE_KEY="0xSUA_CHAVE_PRIVADA_DE_TESTE"

# --- Backend (indexador + API REST) ---
# Porta em que a API do backend vai rodar.
PORT=3001

# URL do nó RPC que o backend vai escutar (padrão: rede local do Hardhat).
RPC_URL="http://127.0.0.1:8545"

# Endereço do contrato CareChainRegistry já publicado.
# É preenchido automaticamente pelo script de deploy em deployments/localhost.json,
# mas você também pode fixá-lo aqui.
CONTRACT_ADDRESS=""
